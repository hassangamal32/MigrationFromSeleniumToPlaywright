# Environment Configuration
ENVIRONMENT=Production

# Production Environment
PROD_BASE_URL=https://eshop.vodafone.com.eg/en/
PROD_API_URL=https://api.vodafone.com.eg/

# Staging Environment
STAGING_BASE_URL=https://staging.eshop.vodafone.com.eg/en/
STAGING_API_URL=https://staging-api.vodafone.com.eg/

# Test Data
PROD_TEST_MSISDN=201012345678
STAGING_TEST_MSISDN=201087654321

# Browser
HEADLESS=false
HEADED_MODE=true

# Reporting
REPORT_AUTO_OPEN=true
ALLURE_REPORT_ENABLE=true

# Timeout (milliseconds)
DEFAULT_TIMEOUT=60000
ELEMENT_TIMEOUT=10000
